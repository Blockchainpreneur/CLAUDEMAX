{
  "fastMode": true,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "export PATH=\"/Users/macbook/.nvm/versions/node/v20.19.0/bin:/usr/local/bin:/usr/bin:/bin:$PATH\" && node ~/.claude/helpers/pii-redactor.mjs",
            "timeout": 2000
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "export PATH=\"/Users/macbook/.nvm/versions/node/v20.19.0/bin:/usr/local/bin:/usr/bin:/bin:$PATH\" && node ~/.claude/helpers/code-quality-gate.mjs 2>/dev/null || true",
            "timeout": 1500
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "export PATH=\"/Users/macbook/.nvm/versions/node/v20.19.0/bin:/usr/local/bin:/usr/bin:/bin:$PATH\" && (lsof -ti:4000 > /dev/null 2>&1 || nohup node \"/Users/macbook/Claudecode Tune/src/dashboard-server.mjs\" >> ~/.claude/logs/dashboard.log 2>&1 &) || true",
            "timeout": 3000
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "adspirer-ads-agent@claude-plugins-official": true,
    "agent-sdk-dev@claude-plugins-official": true,
    "ai-firstify@claude-plugins-official": true,
    "ai-plugins@claude-plugins-official": true,
    "aikido@claude-plugins-official": true,
    "amazon-location-service@claude-plugins-official": true,
    "asana@claude-plugins-official": true,
    "astronomer-data-agents@claude-plugins-official": true,
    "atlan@claude-plugins-official": true,
    "atlassian@claude-plugins-official": true,
    "atomic-agents@claude-plugins-official": true,
    "autofix-bot@claude-plugins-official": true,
    "aws-serverless@claude-plugins-official": true,
    "brightdata-plugin@claude-plugins-official": true,
    "chrome-devtools-mcp@claude-plugins-official": true,
    "circleback@claude-plugins-official": true,
    "full-stack-orchestration@claude-code-workflows": true,
    "security-scanning@claude-code-workflows": true,
    "backend-development@claude-code-workflows": true,
    "javascript-typescript@claude-code-workflows": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "claude-code-workflows": {
      "source": {
        "source": "github",
        "repo": "wshobson/agents"
      }
    }
  }
}
