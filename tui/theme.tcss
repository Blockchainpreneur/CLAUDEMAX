/* econ.vibe theme — Linear/Vercel aesthetic */

Screen {
    background: #0a0a0a;
    color: #ededed;
}

/* ── Layout ── */
#layout {
    layout: horizontal;
    height: 1fr;
}

#sidebar {
    width: 20;
    min-width: 18;
    background: #111111;
    border-right: solid #2a2a2a;
    padding: 0 1;
    overflow-y: auto;
}

#kanban-scroll {
    width: 1fr;
    height: 1fr;
    overflow-x: auto;
    overflow-y: hidden;
}

#kanban {
    layout: horizontal;
    height: 1fr;
    min-width: 98;
    padding: 0 1;
}

#right-panel {
    width: 22;
    min-width: 18;
    background: #111111;
    border-left: solid #2a2a2a;
    padding: 0 1;
    overflow-y: auto;
}

/* ── Sidebar ── */
#app-title {
    text-align: center;
    color: #5865f2;
    text-style: bold;
    padding: 1 0;
    border-bottom: solid #2a2a2a;
}

.sidebar-section-label {
    color: #444444;
    text-style: bold;
    margin-top: 1;
    margin-bottom: 0;
    padding: 0;
}

.sidebar-item {
    color: #666666;
    padding: 0;
    margin: 0;
}

.sidebar-item:hover {
    color: #ededed;
    background: #1a1a1a;
}

.sidebar-item-active {
    color: #ededed;
    background: #1a1a1a;
}

.sidebar-cost {
    color: #f472b6;
    text-style: bold;
    margin-top: 1;
    border-top: solid #2a2a2a;
    padding-top: 1;
}

.sidebar-status {
    color: #666666;
    padding: 0;
}

/* ── Kanban columns ── */
.kanban-column {
    width: 24;
    min-width: 22;
    height: 1fr;
    margin: 0 1;
    layout: vertical;
}

.column-header {
    height: 3;
    padding: 0 1;
    border-bottom: solid #2a2a2a;
    margin-bottom: 1;
}

.column-title {
    text-style: bold;
    color: #ededed;
}

.column-count {
    color: #444444;
}

.col-thinking   { border-top: tall #7c3aed; }
.col-designing  { border-top: tall #2563eb; }
.col-developing { border-top: tall #0891b2; }
.col-testing    { border-top: tall #d97706; }
.col-reviewing  { border-top: tall #9333ea; }
.col-deploying  { border-top: tall #16a34a; }
.col-done       { border-top: tall #374151; }

.column-cards {
    overflow-y: auto;
    height: 1fr;
}

/* ── Agent cards ── */
.agent-card {
    background: #1a1a1a;
    border: solid #2a2a2a;
    margin-bottom: 1;
    padding: 1;
    height: auto;
    min-height: 7;
}

.agent-card:hover {
    background: #222222;
    border: solid #3a3a3a;
}

.agent-card.status-thinking {
    border: solid #7c3aed;
}

.agent-card.status-working {
    border: solid #0891b2;
}

.agent-card.status-done {
    border: solid #22c55e;
    opacity: 0.7;
}

.agent-card.status-error {
    border: solid #ef4444;
}

.agent-card.status-idle {
    border: solid #2a2a2a;
    opacity: 0.5;
}

.card-name {
    text-style: bold;
    color: #ededed;
    margin-bottom: 0;
}

.card-task {
    color: #666666;
    overflow: hidden;
    margin-bottom: 1;
}

.card-progress {
    color: #5865f2;
    margin-bottom: 0;
}

.card-meta {
    color: #444444;
}

/* ── Empty state ── */
.empty-state {
    color: #2a2a2a;
    text-align: center;
    padding: 4 0;
}

/* ── Right panel ── */
.panel-section {
    border-bottom: solid #2a2a2a;
    padding-bottom: 1;
    margin-bottom: 1;
}

.panel-label {
    color: #444444;
    text-style: bold;
    margin-bottom: 0;
}

.panel-value {
    color: #ededed;
    margin: 0;
}

.panel-value-accent {
    color: #5865f2;
    text-style: bold;
}

.panel-value-cost {
    color: #f472b6;
    text-style: bold;
}

.panel-value-success {
    color: #22c55e;
}

.live-indicator {
    color: #22c55e;
}

/* ── Bottom bar ── */
#bottom-bar {
    height: 7;
    background: #111111;
    border-top: solid #2a2a2a;
    padding: 0 1;
    layout: vertical;
}

#prompt-row {
    layout: horizontal;
    height: 3;
    align: left middle;
    border-bottom: solid #2a2a2a;
}

#prompt-prefix {
    color: #5865f2;
    text-style: bold;
    width: 4;
}

#prompt-input {
    background: #111111;
    border: none;
    color: #ededed;
    width: 1fr;
    height: 3;
}

#prompt-input:focus {
    border: none;
    outline: none;
}

#template-row {
    layout: horizontal;
    height: 2;
    align: left middle;
}

.template-btn {
    background: #1a1a1a;
    border: solid #2a2a2a;
    color: #666666;
    margin-right: 1;
    padding: 0 1;
    height: 1;
}

.template-btn:hover {
    background: #222222;
    color: #ededed;
    border: solid #5865f2;
}

#go-btn {
    background: #5865f2;
    border: solid #5865f2;
    color: #ffffff;
    text-style: bold;
    padding: 0 2;
    height: 1;
}

#go-btn:hover {
    background: #6875f5;
}

#keybind-row {
    color: #2a2a2a;
    text-align: center;
    height: 1;
    padding-top: 0;
}

/* ── Notifications ── */
.notification {
    background: #1a1a1a;
    border: solid #2a2a2a;
    padding: 1;
    margin: 1;
    layer: notification;
}

.notification.error {
    border: solid #ef4444;
    color: #ef4444;
}

.notification.success {
    border: solid #22c55e;
    color: #22c55e;
}

/* ── Loading screen ── */
LoadingScreen {
    background: #0a0a0a;
    align: center middle;
    layout: vertical;
}

#loading-title {
    color: #5865f2;
    text-style: bold;
    text-align: center;
    margin-bottom: 1;
}

#loading-sub {
    color: #444444;
    text-align: center;
    margin-bottom: 2;
}

#loading-bar {
    width: 40;
    color: #5865f2;
}

/* ── Size warning ── */
SizeWarningScreen {
    background: #0a0a0a;
    align: center middle;
}

#size-warning {
    color: #f59e0b;
    text-align: center;
}
